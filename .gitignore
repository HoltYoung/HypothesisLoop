# --------------------------------------------------
.vscode/
*.code-workspace

# --------------------------------------------------
# Build outputs / reports / figures
# (generated files should not be versioned)
# --------------------------------------------------
reports/
figures/
outputs/
tool_outputs/
tool_figures/
# --------------------------------------------------
# Logs
# --------------------------------------------------
*.log


# Python packaging artifacts
# --------------------------------------------------
*.egg-info/
dist/
build/

# --------------------------------------------------
# Langfuse
# --------------------------------------------------
infra/
langfuse_logs/
docker-compose.yml

# --------------------------------------------------
# Assignment PDFs (not deliverables)
# --------------------------------------------------
*.pdf
!docs/Langfuse_Tracing_Log_Build3.pdf
!docs/Langfuse_Tracing_Log_Build4.pdf

# --------------------------------------------------
