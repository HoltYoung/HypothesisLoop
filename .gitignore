# --------------------------------------------------
# Python cache / compiled files
# --------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd

# --------------------------------------------------
# Virtual environments
# --------------------------------------------------
.venv/
venv/
env/

# --------------------------------------------------
# Environment variables / secrets
# --------------------------------------------------
.env
.env.*

# --------------------------------------------------
# Jupyter Notebook checkpoints
# --------------------------------------------------
.ipynb_checkpoints/

# --------------------------------------------------
# OS / editor junk files
# --------------------------------------------------
.DS_Store
Thumbs.db

# --------------------------------------------------
