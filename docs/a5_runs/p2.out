- Requested task: Create a boxplot of hours_per_week by income
- Output type: Plot
- Required columns: hours_per_week, income
- Missing-data handling: Drop rows with missing values in hours_per_week and income
- Saved artifact: Boxplot figure saved in --report_dir

CODE:
```python
import argparse
import pandas as pd
import matplotlib.pyplot as plt
import os

def main(data_path, report_dir):
    # Read the dataset
    df = pd.read_csv(data_path)

    # Validate required columns
    required_columns = ['hours_per_week', 'income']
    for col in required_columns:
        if col not in df.columns:
            print(f"Error: Missing required column '{col}' in the dataset.")
            exit(1)

    # Handle missing values by dropping rows with missing data in required columns
    df = df.dropna(subset=required_columns)

    # Create a boxplot of hours_per_week by income
    plt.figure(figsize=(10, 6))
    df.boxplot(column='hours_per_week', by='income', grid=False)
    plt.title('Boxplot of Hours per Week by Income')
    plt.suptitle('')  # Suppress the default title to clean up the plot
    plt.xlabel('Income')
    plt.ylabel('Hours per Week')

    # Save the figure to the report directory
    if not os.path.exists(report_dir):
        os.makedirs(report_dir)
    plt.savefig(os.path.join(report_dir, 'boxplot_hours_per_week_by_income.png'))
    plt.close()

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description='Generate a boxplot of hours per week by income.')
    parser.add_argument('--data', required=True, help='Path to the input CSV data file.')
    parser.add_argument('--report_dir', required=True, help='Directory to save the report artifacts.')
    args = parser.parse_args()

    main(args.data, args.report_dir)
```

